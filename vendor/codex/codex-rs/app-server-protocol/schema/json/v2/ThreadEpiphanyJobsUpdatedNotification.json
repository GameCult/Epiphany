{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ThreadEpiphanyJobsUpdatedNotification",
  "type": "object",
  "required": [
    "source",
    "threadId"
  ],
  "properties": {
    "jobs": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ThreadEpiphanyJob"
      }
    },
    "source": {
      "$ref": "#/definitions/ThreadEpiphanyJobsUpdatedSource"
    },
    "stateRevision": {
      "type": [
        "integer",
        "null"
      ],
      "format": "uint64",
      "minimum": 0.0
    },
    "threadId": {
      "type": "string"
    }
  },
  "definitions": {
    "ThreadEpiphanyJob": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "ownerRole",
        "scope",
        "status"
      ],
      "properties": {
        "activeThreadIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "authorityScope": {
          "type": [
            "string",
            "null"
          ]
        },
        "backendJobId": {
          "type": [
            "string",
            "null"
          ]
        },
        "blockingReason": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "itemsProcessed": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0.0
        },
        "itemsTotal": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0.0
        },
        "kind": {
          "$ref": "#/definitions/ThreadEpiphanyJobKind"
        },
        "lastCheckpointAtUnixSeconds": {
          "type": [
            "integer",
            "null"
          ],
          "format": "int64"
        },
        "launcherJobId": {
          "type": [
            "string",
            "null"
          ]
        },
        "linkedGraphNodeIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "linkedSubgoalIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ownerRole": {
          "type": "string"
        },
        "progressNote": {
          "type": [
            "string",
            "null"
          ]
        },
        "scope": {
          "type": "string"
        },
        "status": {
          "$ref": "#/definitions/ThreadEpiphanyJobStatus"
        }
      }
    },
    "ThreadEpiphanyJobKind": {
      "type": "string",
      "enum": [
        "indexing",
        "remap",
        "verification",
        "specialist"
      ]
    },
    "ThreadEpiphanyJobStatus": {
      "type": "string",
      "enum": [
        "idle",
        "needed",
        "pending",
        "running",
        "completed",
        "failed",
        "cancelled",
        "blocked",
        "unavailable"
      ]
    },
    "ThreadEpiphanyJobsUpdatedSource": {
      "type": "string",
      "enum": [
        "runtimeProgress"
      ]
    }
  }
}