{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gamecult.dev/epiphany/cultnet/epiphany.persona-bubble.schema.json",
  "title": "Epiphany Persona Bubble",
  "description": "Aquarium-visible Persona bubble artifact.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "createdAt": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "projected"
      ]
    },
    "source": {
      "type": "string"
    },
    "target": {
      "type": "string"
    },
    "roleId": {
      "type": "string"
    },
    "agentId": {
      "type": "string"
    },
    "displayName": {
      "type": "string"
    },
    "mood": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "bubble": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string" },
        "anchorRoleId": { "type": "string" },
        "opensIn": { "type": "string" },
        "requiresDiscord": { "type": "boolean" },
        "ttlSeconds": { "type": "integer", "minimum": 0 }
      },
      "required": [
        "kind",
        "anchorRoleId",
        "opensIn",
        "requiresDiscord",
        "ttlSeconds"
      ]
    }
  },
  "required": [
    "schemaVersion",
    "createdAt",
    "status",
    "source",
    "target",
    "roleId",
    "agentId",
    "displayName",
    "mood",
    "content",
    "bubble"
  ]
}
