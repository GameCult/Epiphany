{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gamecult.dev/epiphany/cultnet/epiphany.surface.planning.schema.json",
  "title": "Epiphany planning",
  "description": "Planning projection mirrored from thread/epiphany/planning.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "threadId": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "stateStatus": {
      "type": "string"
    },
    "stateRevision": {
      "type": "integer"
    },
    "planning": {
      "type": "object",
      "additionalProperties": true
    },
    "summary": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "threadId",
    "source",
    "stateStatus",
    "planning",
    "summary"
  ]
}
