{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gamecult.dev/epiphany/cultnet/epiphany.surface.scene.schema.json",
  "title": "Epiphany scene",
  "description": "Operator-safe scene reflection mirrored from thread/epiphany/scene.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "threadId": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "stateStatus": {
      "type": "string"
    },
    "stateRevision": {
      "type": "integer"
    },
    "scene": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "threadId",
    "source",
    "scene"
  ]
}
