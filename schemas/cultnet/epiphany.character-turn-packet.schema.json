{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gamecult.dev/epiphany/cultnet/epiphany.character-turn-packet.schema.json",
  "title": "Epiphany Character Turn Packet",
  "description": "Epiphany-native character-loop projection packet.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "protocol": {
      "type": "object",
      "additionalProperties": true
    },
    "source": {
      "type": "string"
    },
    "createdAt": {
      "type": "string"
    },
    "stimulus": {
      "type": "object",
      "additionalProperties": true
    },
    "projectedLocalContext": {
      "type": "object",
      "additionalProperties": true
    },
    "projectionSeed": {
      "type": "object",
      "additionalProperties": true
    },
    "appraisalSeed": {
      "type": "object",
      "additionalProperties": true
    },
    "reactionSeed": {
      "type": "object",
      "additionalProperties": true
    },
    "allowedOutputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cognitionLanes": {
      "type": "object",
      "additionalProperties": true
    },
    "guardrails": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "resultShape": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "schemaVersion",
    "protocol",
    "source",
    "createdAt",
    "stimulus",
    "projectedLocalContext",
    "projectionSeed",
    "appraisalSeed",
    "reactionSeed",
    "allowedOutputs",
    "cognitionLanes",
    "guardrails",
    "resultShape"
  ]
}
