{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gamecult.dev/epiphany/cultnet/epiphany.memory-graph.schema.json",
  "title": "Epiphany Memory Graph",
  "description": "Unified typed memory graph for repo architecture/dataflow, role memory, heartbeat pressure, incubation, agency, candidate interventions, and evidence. Embeddings are cache metadata, not canonical truth.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "epiphany.memory_graph.v1" },
    "graphId": {
      "type": "string"
    },
    "source": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["kind", "identity", "revision"],
      "properties": {
        "kind": { "type": "string" },
        "identity": { "type": "string" },
        "revision": { "type": "integer", "minimum": 0 }
      }
    },
    "domains": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "summaries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "embeddingManifest": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "freshness": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "lifecycleReceipts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "required": [
    "schemaVersion",
    "graphId"
  ]
}
