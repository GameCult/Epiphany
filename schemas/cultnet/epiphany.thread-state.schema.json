{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gamecult.dev/epiphany/cultnet/epiphany.thread-state.schema.json",
  "title": "Epiphany Thread State",
  "description": "Typed Epiphany control-plane state. Codex rollout storage is a compatibility source, not the logical state contract.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "revision": {
      "type": "integer",
      "minimum": 0
    },
    "objective": {
      "type": [
        "string",
        "null"
      ]
    },
    "activeSubgoalId": {
      "type": [
        "string",
        "null"
      ]
    },
    "subgoals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "invariants": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "graphs": {
      "type": "object",
      "additionalProperties": true
    },
    "observations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "recentEvidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "planning": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "revision"
  ]
}
