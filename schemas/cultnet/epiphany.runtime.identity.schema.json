{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gamecult.dev/epiphany/cultnet/epiphany.runtime.identity.schema.json",
  "title": "Epiphany Runtime Identity",
  "description": "Identity record for the native Epiphany runtime spine.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "description": "Runtime identity payload version."
    },
    "runtimeId": {
      "type": "string"
    },
    "displayName": {
      "type": "string"
    },
    "runtimeKind": {
      "type": "string"
    },
    "createdAt": {
      "type": "string"
    },
    "updatedAt": {
      "type": "string"
    },
    "supportedDocumentTypes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "schemaVersion",
    "runtimeId",
    "displayName",
    "runtimeKind",
    "createdAt",
    "updatedAt",
    "supportedDocumentTypes"
  ]
}
