{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gamecult.dev/epiphany/cultnet/epiphany.surface.jobs.schema.json",
  "title": "Epiphany jobs",
  "description": "Job/progress reflection mirrored from thread/epiphany/jobs.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "threadId": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "stateRevision": {
      "type": "integer"
    },
    "jobs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "required": [
    "threadId",
    "source",
    "jobs"
  ]
}
