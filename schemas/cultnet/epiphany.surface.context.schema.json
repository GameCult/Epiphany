{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gamecult.dev/epiphany/cultnet/epiphany.surface.context.schema.json",
  "title": "Epiphany context",
  "description": "Bounded graph/evidence context shard mirrored from thread/epiphany/context.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "threadId": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "stateStatus": {
      "type": "string"
    },
    "stateRevision": {
      "type": "integer"
    },
    "context": {
      "type": "object",
      "additionalProperties": true
    },
    "missing": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "threadId",
    "source",
    "stateStatus",
    "context",
    "missing"
  ]
}
