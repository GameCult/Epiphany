{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gamecult.dev/epiphany/cultnet/epiphany.runtime.event.schema.json",
  "title": "Epiphany Runtime Event",
  "description": "Append-only native runtime event projection.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "eventId": {
      "type": "string"
    },
    "occurredAt": {
      "type": "string"
    },
    "eventType": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "sessionId": {
      "type": [
        "string",
        "null"
      ]
    },
    "jobId": {
      "type": [
        "string",
        "null"
      ]
    },
    "summary": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "schemaVersion",
    "eventId",
    "occurredAt",
    "eventType",
    "source",
    "summary"
  ]
}
