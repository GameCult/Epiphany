{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gamecult.dev/epiphany/cultnet/epiphany.agent-heartbeat.schema.json",
  "title": "Epiphany Heartbeat State",
  "description": "Stable typed heartbeat scheduler state for initiative, readiness, pacing, pending turns, and history. Experimental cognition thought-weather lives in epiphany.agent-heartbeat-cognition.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "targetHeartbeatRate": {
      "type": "number"
    },
    "sceneClock": {
      "type": "number"
    },
    "selectionPolicy": {
      "type": "object",
      "additionalProperties": true
    },
    "pacingPolicy": {
      "type": "object",
      "additionalProperties": true
    },
    "participants": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "extra": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "schemaVersion",
    "targetHeartbeatRate",
    "sceneClock",
    "selectionPolicy",
    "pacingPolicy",
    "participants",
    "history"
  ]
}
