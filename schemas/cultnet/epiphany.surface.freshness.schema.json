{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gamecult.dev/epiphany/cultnet/epiphany.surface.freshness.schema.json",
  "title": "Epiphany freshness",
  "description": "Read-only freshness reflection over retrieval, watcher, and graph staleness signals.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "threadId": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "stateRevision": {
      "type": "integer"
    },
    "retrieval": {
      "type": "object",
      "additionalProperties": true
    },
    "graph": {
      "type": "object",
      "additionalProperties": true
    },
    "watcher": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "threadId",
    "source",
    "retrieval",
    "graph",
    "watcher"
  ]
}
