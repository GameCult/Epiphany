{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gamecult.dev/epiphany/cultnet/epiphany.surface.roles.schema.json",
  "title": "Epiphany roles",
  "description": "Role ownership reflection mirrored from thread/epiphany/roles.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "threadId": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "stateStatus": {
      "type": "string"
    },
    "stateRevision": {
      "type": "integer"
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "note": {
      "type": "string"
    }
  },
  "required": [
    "threadId",
    "source",
    "stateStatus",
    "roles",
    "note"
  ]
}
