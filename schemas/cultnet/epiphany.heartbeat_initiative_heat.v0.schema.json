{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gamecult.dev/epiphany/cultnet/epiphany.heartbeat_initiative_heat.v0.schema.json",
  "title": "epiphany heartbeat_initiative_heat v0",
  "description": "Heartbeat initiative heat policy. Multipliers accelerate or relax turn recovery without granting project authority.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "schemaVersion": {
      "const": "epiphany.heartbeat_initiative_heat.v0"
    },
    "globalMultiplier": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "multipliers": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/multiplier"
      }
    }
  },
  "required": [
    "schemaVersion",
    "globalMultiplier",
    "multipliers"
  ],
  "definitions": {
    "scope": {
      "type": "string",
      "enum": [
        "global",
        "all",
        "agent",
        "agent_id",
        "role",
        "role_id",
        "arena",
        "participant_kind",
        "kind",
        "group",
        "constraint"
      ]
    },
    "multiplier": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        },
        "scope": {
          "$ref": "#/definitions/scope"
        },
        "selector": {
          "type": "string"
        },
        "multiplier": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "reason": {
          "type": "string"
        },
        "updatedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "expiresAtSceneClock": {
          "type": [
            "number",
            "null"
          ]
        }
      },
      "required": [
        "id",
        "scope",
        "selector",
        "multiplier"
      ]
    }
  }
}
