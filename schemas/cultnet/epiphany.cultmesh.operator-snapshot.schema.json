{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gamecult.dev/epiphany/cultnet/epiphany.cultmesh.operator-snapshot.schema.json",
  "title": "Epiphany CultMesh Operator Snapshot",
  "description": "Bounded typed CultCache tuple distilled from an operator-safe run/status artifact. Raw Codex app-server JSON remains an edge artifact; this document is the native Epiphany receipt.",
  "type": "array",
  "minItems": 18,
  "maxItems": 18,
  "items": [
    {
      "title": "schemaVersion",
      "type": "string",
      "const": "epiphany.cultmesh.operator_snapshot.v0"
    },
    {
      "title": "runtimeId",
      "type": "string"
    },
    {
      "title": "verseId",
      "type": "string"
    },
    {
      "title": "snapshotId",
      "type": "string"
    },
    {
      "title": "generatedAtUtc",
      "type": "string"
    },
    {
      "title": "sourceMode",
      "type": "string"
    },
    {
      "title": "sourcePath",
      "type": "string"
    },
    {
      "title": "threadId",
      "type": "string"
    },
    {
      "title": "status",
      "type": "string"
    },
    {
      "title": "stateStatus",
      "type": "string"
    },
    {
      "title": "coordinatorAction",
      "type": "string"
    },
    {
      "title": "crrcAction",
      "type": "string"
    },
    {
      "title": "pressureLevel",
      "type": "string"
    },
    {
      "title": "reorientAction",
      "type": "string"
    },
    {
      "title": "nextAction",
      "type": "string"
    },
    {
      "title": "artifactRefs",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    {
      "title": "availableActions",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    {
      "title": "notes",
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  ]
}
