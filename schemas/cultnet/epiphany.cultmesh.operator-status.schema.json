{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gamecult.dev/epiphany/cultnet/epiphany.cultmesh.operator-status.schema.json",
  "title": "Epiphany CultMesh Operator Status",
  "description": "Native operator-status CultCache tuple naming the Codex bridge role, Epiphany authority role, prompt boundary, and quarantined optional bridge surfaces.",
  "type": "array",
  "minItems": 12,
  "maxItems": 12,
  "items": [
    {
      "title": "schemaVersion",
      "type": "string",
      "const": "epiphany.cultmesh.operator_status.v0"
    },
    {
      "title": "runtimeId",
      "type": "string"
    },
    {
      "title": "verseId",
      "type": "string"
    },
    {
      "title": "surfaceId",
      "type": "string"
    },
    {
      "title": "status",
      "type": "string"
    },
    {
      "title": "generatedAtUtc",
      "type": "string"
    },
    {
      "title": "summary",
      "type": "string"
    },
    {
      "title": "codexBridgeRole",
      "type": "string"
    },
    {
      "title": "epiphanyAuthorityRole",
      "type": "string"
    },
    {
      "title": "promptAuthority",
      "type": "string"
    },
    {
      "title": "nativeAuthorities",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    {
      "title": "quarantinedSurfaces",
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  ]
}
